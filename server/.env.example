MONGODB_URI=mongodb+srv://<db_user>:<db_password>@cluster0.example.mongodb.net/tracking_speed_reading?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

# Optional (if not set, server uses JWT_SECRET for encryption)
ENCRYPTION_KEY=replace-with-another-long-random-secret

PORT=5050
NODE_ENV=production

# IMPORTANT:
# Add your Vercel frontend URL(s), comma-separated
# Example: https://tracking-speed-reading.vercel.app,https://www.your-domain.com
CORS_ORIGIN=https://your-vercel-domain.vercel.app

# First admin account (run seed script after deploy if needed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Admin
